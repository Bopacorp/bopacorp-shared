{
"compilerOptions": {
  "rootDir": "src",
  "outDir": "dist",
  "module": "nodenext",
  "moduleResolution": "nodenext",
  "target": "ES2022",
  "strict": true,
  "declaration": true,
  "verbatimModuleSyntax": true,
  "skipLibCheck": true
},
"include": ["src"],
"exclude": ["dist", "node_modules"]
}
